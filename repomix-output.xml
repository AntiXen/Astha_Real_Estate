                      >
                        <Edit className="h-3 w-3" />
                      </button>
                      <button 
                        onClick={() => onDeleteProperty(p.id)} 
                        className="p-1.5 rounded bg-rose-50 hover:bg-rose-100 text-rose-600 transition cursor-pointer"
